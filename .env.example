# =============================================================================
# LyCore Environment Configuration - Example
# =============================================================================
# Use one external CRM/scheduling platform for the beginner setup.
# Recommended free-first option right now: Agile CRM, because its free CRM page
# lists web forms/popups and an online appointment calendar.
# =============================================================================

# Public CRM intake form link.
# Paste the published form URL from your chosen CRM platform.
VITE_AUDIT_FORM_URL=""

# Public booking/calendar link.
# Paste the published appointment calendar URL from the same platform.
VITE_BOOKING_URL=""

# Use these public URLs inside Zoho redirect settings:
# Form success redirect: https://www.lycore.org/audit-request-received
# Booking success redirect: https://www.lycore.org/booking-confirmed
# Booking failure redirect: https://www.lycore.org/booking-failed

# Public production URL.
APP_URL="https://lycore.org"

# Local development port.
PORT="3000"
