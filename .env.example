# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- CRM / Lead Routing -----------------------------------------------------
# Optional generic webhook URL for forwarding validated leads into a CRM or
# automation tool (HubSpot, Bitrix24, Zoho, Make, Zapier, n8n, Airtable, Supabase, etc.).
CRM_WEBHOOK_URL=""

# Preferred when Zoho is the CRM. This should be a server-side webhook receiver
# from Zoho Flow, a Zoho CRM workflow/function webhook, Make, Zapier, or n8n.
# Requires manual setup: map the incoming LyCore lead payload to Zoho fields.
ZOHO_CRM_WEBHOOK_URL=""

# Optional calendar/appointment webhook. Use this when a valid audit form should
# also create or prepare a calendar/booking action.
CALENDAR_WEBHOOK_URL=""

# Preferred when Zoho Calendar, Zoho Bookings, or Zoho Flow handles appointments.
# Requires manual setup: map preferredContactTime, contact details, and notes.
ZOHO_CALENDAR_WEBHOOK_URL=""

# --- Owner Notifications ----------------------------------------------------
# Webhook URL to notify the agency owner when a new qualified lead arrives.
# Can point to Slack, Discord, email-via-webhook, Make/Zapier, or a custom endpoint.
OWNER_NOTIFICATION_WEBHOOK=""

# Email address to receive lead notification summaries (requires SMTP setup).
OWNER_NOTIFICATION_EMAIL=""

# --- SMTP / Email (for owner notifications and follow-up) -------------------
# Required only if you want to send email notifications directly from the server.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# --- Analytics ---------------------------------------------------------------
# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX).
# Used by the frontend analytics utility when gtag.js is loaded.
GA4_MEASUREMENT_ID=""

# --- Booking / Appointment ---------------------------------------------------
# External booking/calendar URL (Cal.com, Calendly, TidyCal, etc.)
# The chatbot and CTA can direct qualified leads to this URL.
VITE_BOOKING_URL=""

# Server-side booking URL included in webhook payloads. This may match VITE_BOOKING_URL.
BOOKING_URL=""

# --- Retell AI / Voice Agent -------------------------------------------------
# If using Retell AI or similar for phone-based AI receptionist.
RETELL_API_KEY=""
RETELL_AGENT_ID=""

# --- Application ------------------------------------------------------------
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
