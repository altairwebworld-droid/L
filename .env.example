# =============================================================================
# LyCore Environment Configuration - Example
# =============================================================================
# This setup uses Jotform for intake, Cal.com for booking, GA4 for analytics,
# and Gemini for the AI chat endpoint.
# Do not put private keys in VITE_* variables.
# =============================================================================

# -----------------------------------------------------------------------------
# LEAD BACKEND — configure AT LEAST ONE of the three channels below.
# The /api/leads route sends every audit lead to ALL configured channels and
# succeeds when at least one delivers. With none configured, leads are rejected.
# -----------------------------------------------------------------------------

# Option A (fastest, ~5 min): a webhook URL that receives the lead as JSON.
# Works with Make.com, Zapier, n8n, or a Google Apps Script web app that writes
# to a Google Sheet. Create the webhook there, paste the URL here.
LEAD_WEBHOOK_URL=""

# Option B: email notification for every lead via Resend (resend.com, free tier).
# LEADS_NOTIFY_EMAIL is where leads are sent (e.g. services@lycore.org).
# LEADS_FROM_EMAIL requires a verified domain in Resend; leave blank to use
# Resend's onboarding sender while testing.
RESEND_API_KEY=""
LEADS_NOTIFY_EMAIL=""
LEADS_FROM_EMAIL=""

# Option C: Jotform API. Requires real field IDs in src/server/leadRouting.ts.
JOTFORM_API_KEY=""
JOTFORM_FORM_ID="261873053708057"

# Optional extra webhooks (each also counts as a configured channel):
# CRM_WEBHOOK_URL=""             # generic CRM webhook
# ZOHO_CRM_WEBHOOK_URL=""        # Zoho-specific webhook
# CALENDAR_WEBHOOK_URL=""        # booking/calendar automation
# OWNER_NOTIFICATION_WEBHOOK=""  # e.g. Slack/SMS notification flow
# FOLLOW_UP_WEBHOOK_URL=""       # follow-up sequence trigger

# Public Cal.com booking link shown on /book.
# VITE_ vars are baked in at build time — set this in Vercel too, then redeploy.
VITE_BOOKING_URL="https://cal.com/your-username/your-event"

# Cal.com API key (optional; not used by code yet — reserved for API-based booking).
CAL_API_KEY=""

# Google Analytics 4 measurement ID.
# Find it in GA4 Admin > Data streams > Web > Measurement ID. Format: G-XXXXXXXXXX.
VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Gemini API key used by the website AI chat endpoint.
# Keep this server-side only. Do not prefix it with VITE_.
GEMINI_API_KEY=""

# Cal.com redirect URLs:
# Calendar booking success redirect: https://lycore.org/booking-confirmed
# Calendar booking failed/canceled redirect: https://lycore.org/booking-failed

# Public production URL.
APP_URL="https://lycore.org"

# Local development port.
PORT="3000"
