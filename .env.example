# =============================================================================
# LyCore Environment Configuration - Example
# =============================================================================
# Use one external CRM/scheduling platform for the beginner setup.
# Pick a platform that can publish an intake form and a calendar/booking link,
# or use the built-in /api/leads endpoint until a CRM is selected.
# =============================================================================

# Public CRM intake form link.
# Paste the published form URL from your chosen CRM platform.
VITE_AUDIT_FORM_URL=""

# Public booking/calendar link.
# Paste the published appointment calendar URL from the same platform.
VITE_BOOKING_URL=""

# Google Analytics 4 measurement ID.
# Find it in GA4 Admin > Data streams > Web > Measurement ID. Format: G-XXXXXXXXXX.
VITE_GA4_MEASUREMENT_ID=""

# Use these public URLs inside your form/calendar platform redirect settings:
# Intake form success redirect: https://lycore.org/audit-request-received
# Calendar booking success redirect: https://lycore.org/booking-confirmed
# Calendar booking failed/canceled redirect: https://lycore.org/booking-failed

# Public production URL.
APP_URL="https://lycore.org"

# Local development port.
PORT="3000"
