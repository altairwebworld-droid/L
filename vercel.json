{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "lycore.org"
        }
      ],
      "destination": "https://www.lycore.org",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "lycore.org"
        }
      ],
      "destination": "https://www.lycore.org/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 10
    }
  }
}
